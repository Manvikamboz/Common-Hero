# -----------------------------------------------------------------------------
# Community Hero - Hyperlocal Civic Issue Platform Environment Variables Template
# Copy this file to '.env.local' and supply actual credentials for local development.
# -----------------------------------------------------------------------------

# --- Google AI Studio (Gemini API) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Maps API ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# --- Firebase Client SDK configuration ---
# (If left empty or set to 'mock-api-key', the app operates in local client-side Demo mode)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# --- Firebase Admin SDK Credentials ---
# (Used in Next.js Serverless API endpoints for secure database & auth operations)
# Ensure private key handles literal newlines correctly (replace \n characters)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC7...\n-----END PRIVATE KEY-----\n"
